all:
  children:
    homelab:
      hosts:
        my-vm:
          ansible_host: 192.168.1.100     # your VM's local IP (or domain)
          ansible_user: ubuntu            # SSH user with sudo access
          ansible_ssh_private_key_file: ~/.ssh/id_ed25519

          # Role overrides (optional — defaults in roles/ekorepetycje/defaults/main.yml)
          app_branch: main
          cloudflare_tunnel_hostname: ekorepetycje.yourdomain.com
          cloudflare_tunnel_uuid: abc12345-xxxx-xxxx-xxxx-xxxxxxxxxxxx
