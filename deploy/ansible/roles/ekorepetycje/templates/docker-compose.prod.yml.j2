# Production overrides — generated by Ansible
services:
  db:
    restart: always

  web:
    restart: always
    command: uvicorn app.main:app --host 0.0.0.0 --port {{ app_port }} --workers {{ app_workers }}
    volumes: []   # override dev bind-mounts — use image layers only

volumes:
  postgres_data:
    external: true
