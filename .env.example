# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@db:5432/ekorepetycje
SECRET_KEY=your-secret-key-here
DEBUG=True
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=ekorepetycje

# ── Email — Resend (https://resend.com) ───────────────────────────────────────
# Leave blank to fall back to logging (safe for local dev / CI).
# Get a free API key at https://resend.com — 3 000 emails/month free.
RESEND_API_KEY=
# Must be a verified sender domain in Resend. Use onboarding@resend.dev for testing.
RESEND_FROM_EMAIL=Ekorepetycje <onboarding@resend.dev>
# Where contact form submissions are delivered.
RESEND_TO_EMAIL=kontakt@ekorepetycje.pl

# ── CAPTCHA — Cloudflare Turnstile (https://dash.cloudflare.com) ──────────────
# Default values are Cloudflare's official test keys — always pass, never for prod.
# Get real keys: Cloudflare Dashboard → Turnstile → Add site.
TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
