# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:CHANGE_ME_DB_PASSWORD@db:5432/ekorepetycje
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
POSTGRES_DB=ekorepetycje

# ── Application ───────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Minimum 64 hex characters (32 bytes). NEVER use the placeholder in production.
SECRET_KEY=CHANGE_ME_RUN_python_-c_import_secrets_print_secrets.token_hex_32_
DEBUG=False

# ── Email — Resend (https://resend.com) ───────────────────────────────────────
# Leave blank to fall back to console logging (safe for local dev / CI).
# Get a free API key at https://resend.com — 3 000 emails/month free.
RESEND_API_KEY=
# Must be a verified sender domain in Resend. Use onboarding@resend.dev for testing.
RESEND_FROM_EMAIL=Ekorepetycje <onboarding@resend.dev>
# Where contact form submissions are delivered.
RESEND_TO_EMAIL=kontakt@ekorepetycje.pl

# ── CAPTCHA — Cloudflare Turnstile (https://dash.cloudflare.com) ──────────────
# Values below are Cloudflare's official test keys — always pass, safe for local dev.
# REQUIRED for production: get real keys at Cloudflare Dashboard → Turnstile → Add site.
TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
