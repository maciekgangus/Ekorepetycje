# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:CHANGE_ME_DB_PASSWORD@db:5432/ekorepetycje
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
POSTGRES_DB=ekorepetycje

# ── Application ───────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Minimum 64 hex characters (32 bytes). NEVER use the placeholder in production.
SECRET_KEY=CHANGE_ME_RUN_python_-c_import_secrets_print_secrets.token_hex_32_
DEBUG=False

# ── Email — Resend (https://resend.com) ───────────────────────────────────────
# Leave blank to fall back to console logging (safe for local dev / CI).
# Get a free API key at https://resend.com — 3 000 emails/month free.
RESEND_API_KEY=
# Must be a verified sender domain in Resend. Use onboarding@resend.dev for testing.
RESEND_FROM_EMAIL=Ekorepetycje <onboarding@resend.dev>
# Where contact form submissions are delivered.
RESEND_TO_EMAIL=kontakt@ekorepetycje.pl

# ── Backup — pg_dump → S3 (scripts/backup_db.py) ─────────────────────────────
# AWS credentials — use an IAM user with s3:PutObject + s3:ListBucket + s3:DeleteObject
# on the target bucket only (principle of least privilege).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-central-1
BACKUP_S3_BUCKET=my-ekorepetycje-backups
BACKUP_S3_PREFIX=ekorepetycje/db
BACKUP_RETAIN_DAYS=30
# Optional: also keep a local copy (leave blank to disable)
BACKUP_LOCAL_DIR=
# Postgres connection used by the backup script (defaults to localhost:5432)
# When running against Docker from the host, set POSTGRES_HOST=127.0.0.1

# ── AI Chat ───────────────────────────────────────────────────────────────────
# LLM_PROVIDER=ollama   (default) — local Ollama server for dev/CPU
# LLM_PROVIDER=bedrock            — Amazon Bedrock for production
LLM_PROVIDER=ollama

# Ollama (dev): model to use — llama3.2:3b (fast, 2 GB) | llama3.1:8b (better, 5 GB)
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:3b

# Bedrock (prod): Claude model ID — us-east-1 or us-west-2 only for Claude
# IAM policy needed: bedrock:InvokeModelWithResponseStream on the model ARN
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# ── CAPTCHA — Cloudflare Turnstile (https://dash.cloudflare.com) ──────────────
# Values below are Cloudflare's official test keys — always pass, safe for local dev.
# REQUIRED for production: get real keys at Cloudflare Dashboard → Turnstile → Add site.
TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
